# Data & large artifacts (never commit) — keep the dirs, ignore their contents
/data/
/feature_cache/*
!/feature_cache/.gitkeep
/outputs/*
!/outputs/.gitkeep
*.jpg
*.jpeg
*.png
!docs/**/*.png

# Python
__pycache__/
*.egg-info/
.pytest_cache/
.venv/
venv/
*.pyc

# OS / editor
.DS_Store
.idea/
.vscode/
